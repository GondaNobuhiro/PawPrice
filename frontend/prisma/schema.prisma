generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                BigInt             @id @default(autoincrement())
  sessionId         String?            @unique @map("session_id")
  email             String?            @unique
  passwordHash      String?            @map("password_hash")
  displayName       String?            @map("display_name")
  notifyEnabled     Boolean            @default(true) @map("notify_enabled")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  watchlists        Watchlist[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model Category {
  id               BigInt  @id @default(autoincrement())
  code             String  @unique
  name             String
  parentCategoryId BigInt? @map("parent_category_id")

  parent   Category?  @relation("CategoryTree", fields: [parentCategoryId], references: [id])
  children Category[] @relation("CategoryTree")

  products    Product[]

  @@map("categories")
}

model Brand {
  id         BigInt      @id @default(autoincrement())
  name       String      @unique
  products   Product[]
  brandRules BrandRule[]

  @@map("brands")
}

model BrandRule {
  id        BigInt   @id @default(autoincrement())
  brandId   BigInt   @map("brand_id")
  keyword   String
  priority  Int      @default(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id])

  @@unique([brandId, keyword])
  @@map("brand_rules")
}

model Product {
  id             BigInt   @id @default(autoincrement())
  categoryId     BigInt   @map("category_id")
  category       Category @relation(fields: [categoryId], references: [id])
  brandId        BigInt?  @map("brand_id")
  name           String
  normalizedName String?  @map("normalized_name")
  janCode        String?  @map("jan_code")
  modelNumber    String?  @map("model_number")
  petType        String   @map("pet_type")
  packageSize    String?  @map("package_size")
  imageUrl       String?  @map("image_url")
  description    String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  brand         Brand?         @relation(fields: [brandId], references: [id])
  offers        ProductOffer[]
  watchlists    Watchlist[]
  notifications Notification[]

  @@index([categoryId, isActive])
  @@index([isActive, createdAt])
  @@map("products")
}

model ProductOffer {
  id                 BigInt   @id @default(autoincrement())
  productId          BigInt   @map("product_id")
  shopType           String   @map("shop_type")
  externalItemId     String   @map("external_item_id")
  externalUrl        String   @map("external_url")
  title              String
  sellerName         String?  @map("seller_name")
  price              Int
  shippingFee        Int?     @map("shipping_fee")
  pointAmount        Int      @default(0) @map("point_amount")
  effectivePrice     Int      @map("effective_price")
  currency           String   @default("JPY")
  availabilityStatus String?  @map("availability_status")
  imageUrl           String?  @map("image_url")
  lastFetchedAt      DateTime @map("last_fetched_at")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  product        Product        @relation(fields: [productId], references: [id])
  priceHistories PriceHistory[]
  notifications  Notification[]

  @@unique([shopType, externalItemId])
  @@index([productId, isActive, effectivePrice])
  @@map("product_offers")
}

model PriceHistory {
  id             BigInt   @id @default(autoincrement())
  productOfferId BigInt   @map("product_offer_id")
  price          Int
  shippingFee    Int?     @map("shipping_fee")
  pointAmount    Int      @default(0) @map("point_amount")
  effectivePrice Int      @map("effective_price")
  fetchedAt      DateTime @map("fetched_at")
  createdAt      DateTime @default(now()) @map("created_at")

  productOffer ProductOffer @relation(fields: [productOfferId], references: [id])

  @@index([productOfferId, fetchedAt])
  @@map("price_histories")
}

model Watchlist {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  productId BigInt   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  watchCondition WatchCondition?

  @@unique([userId, productId])
  @@map("watchlists")
}

model WatchCondition {
  id                BigInt   @id @default(autoincrement())
  watchlistId       BigInt   @unique @map("watchlist_id")
  targetPrice       Int?     @map("target_price")
  notifyOnPriceDrop Boolean  @default(true) @map("notify_on_price_drop")
  notifyOnLowest    Boolean  @default(false) @map("notify_on_lowest")
  lastNotifiedPrice Int?     @map("last_notified_price")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  watchlist Watchlist @relation(fields: [watchlistId], references: [id])

  @@map("watch_conditions")
}

model Notification {
  id               BigInt    @id @default(autoincrement())
  userId           BigInt    @map("user_id")
  productId        BigInt    @map("product_id")
  productOfferId   BigInt?   @map("product_offer_id")
  notificationType String    @map("notification_type")
  subject          String
  body             String
  sentAt           DateTime? @map("sent_at")
  status           String    @default("pending")
  isRead           Boolean   @default(false) @map("is_read")
  createdAt        DateTime  @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id])
  product      Product       @relation(fields: [productId], references: [id])
  productOffer ProductOffer? @relation(fields: [productOfferId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model PushSubscription {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  endpoint  String   @unique
  p256dhKey String   @map("p256dh_key")
  authKey   String   @map("auth_key")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("push_subscriptions")
}

model Genre {
  id                    BigInt   @id @default(autoincrement())
  platform              String
  externalGenreId       String   @map("external_genre_id")
  name                  String
  parentExternalGenreId String?  @map("parent_external_genre_id")
  level                 Int?
  isPetGenre            Boolean  @default(false) @map("is_pet_genre")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([platform, externalGenreId])
  @@index([platform, level, isPetGenre, isActive])
  @@map("genres")
}
